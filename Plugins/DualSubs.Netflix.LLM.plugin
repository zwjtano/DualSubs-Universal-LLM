#!name = 🍿️ DualSubs: 🇳 Netflix LLM v0.5.7.5
#!desc = Netflix 增强及双语字幕\nLLM 翻译版 v0.5.7.5
#!openUrl = http://boxjs.com/#/app/DualSubs.Netflix
#!author = zwjtano[https://github.com/zwjtano]
#!homepage = https://github.com/zwjtano/DualSubs-Universal-LLM
#!icon = https://github.com/DualSubs/Netflix/raw/main/src/assets/icon_rounded.png
#!tag = 🍿️ DualSubs
#!system = iOS,iPadOS,macOS,tvOS
#!date = 2024-12-10 08:53:59
#!version = 0.5.7.5
#!system_version = 15

[Argument]
Type = select,"Translate",,tag=[字幕] 启用类型,desc=请选择要使用的字幕，双语字幕将使用您选择类型呈现。
Languages[0] = select,"AUTO","ZH","ZH-HANS","ZH-HK","ZH-HANT","EN","ES","JA","KO","DE","FR","TR","KM",tag=[字幕] 主语言（源语言）,desc=当“主语言”字幕存在时，将生成“主语言/副语言（翻译）”与“主语言（外挂）”的字幕或字幕选项。仅当源语言识别不准确时更改此选项。
Languages[1] = select,"ZH","ZH-HANS","ZH-HK","ZH-HANT","EN","ES","JA","KO","DE","FR","TR","KM",tag=[字幕] 副语言（目标语言）,desc=当“副语言”字幕存在时，将生成“副语言/主语言（官方）”的字幕或字幕选项。
Position = select,"Forward","Reverse",tag=[字幕] 主语言（源语言）字幕位置,desc=主语言（源语言）字幕的显示位置。
Vendor = select,"LLM","Google","Microsoft",tag=[翻译器] 服务商API,desc=请选择翻译器所使用的服务商API，更多翻译选项请使用BoxJs。
LLMEndpoint = input,"https://api.openai.com/v1/chat/completions",tag=[大模型] API 地址
LLMModel = input,"gpt-4.1-mini",tag=[大模型] 模型名称
LLMAuth = input,"",tag=[大模型] API Key
LLMTemperature = input,"0.2",tag=[大模型] 温度
LLMTimeout = input,"120000",tag=[大模型] 超时毫秒
LLMHeaders = input,"",tag=[大模型] 附加请求头,desc=可选 JSON 对象
ShowOnly = switch,false,tag=[翻译器] 只显示翻译字幕,desc=是否仅显示翻译后字幕，不显示源语言字幕。
LogLevel = select,"WARN","OFF","ERROR","INFO","DEBUG","ALL",tag=[调试] 日志等级,desc=选择脚本日志的输出等级，低于所选等级的日志将全部输出。

[Script]
generic script-path=https://raw.githubusercontent.com/zwjtano/DualSubs-Universal-LLM/main/Scripts/DualSubs/ValidateModel.js,tag=🧪 验证大模型,timeout=60,img-url=checkmark.seal.fill,argument=[{LLMEndpoint},{LLMModel},{LLMAuth},{LLMTimeout},{LLMHeaders}],enable=true

http-response ^https?:\/\/(.+)\.oca\.nflxvideo\.net\/\?o=\d+&v=\d+&e=\d+&t=.+ requires-body=1, timeout=180, script-path=https://raw.githubusercontent.com/zwjtano/DualSubs-Universal-LLM/main/Scripts/DualSubs/Translate.response.bundle.js?v=1.0.1, tag=🍿️ DualSubs.Netflix.Translate.Subtitles.response, argument=[{LLMEndpoint},{LLMModel},{LLMAuth},{LLMTemperature},{LLMTimeout},{LLMHeaders}]

[MITM]
hostname = *.oca.nflxvideo.net
